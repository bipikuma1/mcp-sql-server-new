# -----------------------------------------------------------------------
# MSSQL MCP Server — Environment Variables
# Copy this to .env for local development (never commit .env)
# -----------------------------------------------------------------------

# --- Azure SQL connection string (recommended for ACA) -----------------
# Paste the ADO.NET connection string from Azure Portal:
#   Azure SQL DB → Connection strings → ADO.NET
# Example:
# MSSQL_CONNECTION_STRING=Server=tcp:myserver.database.windows.net,1433;Initial Catalog=mydb;User ID=myuser;Password=mypassword;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

MSSQL_CONNECTION_STRING=


# --- API key for MCP endpoint authentication ---------------------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then set the same value in your ACA secret and AI Foundry connection.

MCP_API_KEY=


# --- Optional: HTTP server binding (defaults shown) --------------------
# HOST=0.0.0.0
# PORT=8080


# -----------------------------------------------------------------------
# Legacy individual env vars (used when MSSQL_CONNECTION_STRING is NOT set)
# -----------------------------------------------------------------------
# MSSQL_SERVER=localhost
# MSSQL_DATABASE=your_database
# MSSQL_USER=your_username
# MSSQL_PASSWORD=your_password
# MSSQL_PORT=1433
# MSSQL_ENCRYPT=false
# MSSQL_WINDOWS_AUTH=false
